{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache" }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/cron-reminders",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron-expire",
      "schedule": "0 0 * * *"
    }
  ]
}
